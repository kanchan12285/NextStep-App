<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.NextStep" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/neon_pink</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/neon_purple</item>
        <item name="colorAccent">@color/neon_purple</item>

        <!-- Removed translucent status bar -->
        <!-- <item name="android:windowTranslucentStatus">true</item> -->

        <!-- Set status bar color to transparent to extend app bar behind status bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>

        <item name="android:colorBackground">@color/background_primary</item>
        <item name="colorSurface">@color/background_secondary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <item name="android:navigationBarColor">@color/background_primary</item>

        <item name="android:windowLightStatusBar">false</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:windowBackground">@color/background_primary</item>
    </style>

    <style name="Theme.NextStep.NoActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/neon_pink</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/neon_purple</item>
        <item name="colorAccent">@color/neon_purple</item>

        <!-- Removed translucent status bar -->
        <!-- <item name="android:windowTranslucentStatus">true</item> -->

        <!-- Set status bar color to transparent -->
        <item name="android:statusBarColor">@android:color/transparent</item>

        <item name="android:colorBackground">@color/background_primary</item>
        <item name="colorSurface">@color/background_secondary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <item name="android:navigationBarColor">@color/background_primary</item>

        <item name="android:windowLightStatusBar">false</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:windowBackground">@color/background_primary</item>
    </style>

    <!-- ADDED: Missing AppBar overlay styles -->
    <style name="Theme.NextStep.AppBarOverlay" parent="ThemeOverlay.MaterialComponents.Dark.ActionBar">
        <item name="colorPrimary">@color/neon_pink</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="actionMenuTextColor">@color/text_primary</item>
    </style>

    <style name="Theme.NextStep.PopupOverlay" parent="ThemeOverlay.MaterialComponents.Light">
        <item name="colorPrimary">@color/neon_pink</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="android:colorBackground">@color/background_secondary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
    </style>

</resources>
