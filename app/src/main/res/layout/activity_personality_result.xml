<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_background_primary"
    tools:context=".PersonalityResultActivity">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/dark_background_secondary">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/quiz_results_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_light"
            android:gravity="center" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Congratulations Message -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/congratulations_message"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/accent_green"
                android:textAlignment="center"
                android:layout_marginBottom="16dp" />

            <!-- Result Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_card_background"
                android:padding="24dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/your_personality_type"
                    android:textSize="16sp"
                    android:textColor="@color/text_medium"
                    android:textAlignment="center"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvPersonalityResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_purple"
                    android:textAlignment="center"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/tvResultDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/text_light"
                    android:textAlignment="center"
                    android:layout_marginBottom="12dp" />

                <!-- Added: Container for trait scores -->
                <LinearLayout
                    android:id="@+id/llTraitScoresContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

            <!-- Action Buttons -->
            <Button
                android:id="@+id/btnViewPersonalityCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/view_personality_card"
                android:textColor="@color/button_text_light"
                android:textStyle="bold"
                android:background="@drawable/rounded_button_background"
                android:backgroundTint="@color/accent_purple"
                android:paddingVertical="16dp"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnRetakeQuiz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/retake_quiz_button"
                android:textColor="@color/text_medium"
                android:background="@drawable/rounded_button_background"
                android:backgroundTint="@color/dark_background_secondary"
                android:paddingVertical="16dp"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnBackToHome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/back_to_home"
                android:textColor="@color/text_medium"
                android:background="@android:color/transparent"
                android:padding="8dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
