<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/rounded_card_background"
    android:padding="16dp"
    android:layout_margin="8dp">

    <!-- Challenge Title -->
    <TextView
        android:id="@+id/tvChallengeTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/color_challenge_title"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/text_light"
        android:layout_marginBottom="8dp" />

    <!-- Difficulty Level -->
    <TextView
        android:id="@+id/tvDifficulty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/difficulty_placeholder"
        android:textSize="12sp"
        android:textColor="@color/text_medium"
        android:background="@drawable/rounded_button_background"
        android:backgroundTint="@color/accent_blue"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:layout_marginBottom="12dp" />

    <!-- Color Palette Preview -->
    <LinearLayout
        android:id="@+id/llColorPreview"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">
        <!-- Color swatches added dynamically -->
    </LinearLayout>

    <!-- Challenge Description -->
    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/color_challenge_description"
        android:textSize="14sp"
        android:textColor="@color/text_medium"
        android:maxLines="2"
        android:ellipsize="end" />

</LinearLayout>
