<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/rounded_card_background"
    android:padding="20dp"
    android:layout_margin="12dp"
    android:elevation="4dp">

    <TextView
        android:id="@+id/tvChallengeDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/challenge_description_placeholder"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/accent_blue"
        android:layout_marginBottom="12dp"
        android:fontFamily="sans-serif-condensed" />

    <TextView
        android:id="@+id/tvBuggyCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/buggy_code_placeholder"
        android:textSize="16sp"
        android:textColor="@color/text_light"
        android:background="@drawable/rounded_edittext_background"
        android:padding="16dp"
        android:fontFamily="monospace"
        android:layout_marginBottom="20dp"
        android:elevation="2dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/choose_correct_fix"
        android:textSize="18sp"
        android:textStyle="italic"
        android:textColor="@color/text_medium"
        android:layout_marginBottom="16dp"
        android:fontFamily="sans-serif" />

    <LinearLayout
        android:id="@+id/llChallengeOptions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

</LinearLayout>
