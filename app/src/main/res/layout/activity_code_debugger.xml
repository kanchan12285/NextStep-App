<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/dark_background_primary"
        android:padding="24dp">

        <!-- Timer and Score container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/timer_placeholder"
                android:textSize="26sp"
                android:textColor="@color/neon_pink"
                android:textStyle="bold"
                android:gravity="start"
                android:fontFamily="sans-serif-condensed" />

            <TextView
                android:id="@+id/tvScore"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/score_placeholder"
                android:textSize="26sp"
                android:textColor="@color/neon_blue"
                android:textStyle="bold"
                android:gravity="end"
                android:fontFamily="sans-serif-condensed" />
        </LinearLayout>

        <!-- Instructions -->
        <TextView
            android:id="@+id/tvInstructions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/instructions_code_debugger"
            android:textSize="18sp"
            android:textColor="@color/text_light"
            android:textAlignment="center"
            android:layout_marginBottom="32dp"
            android:fontFamily="sans-serif" />

        <!-- Feedback -->
        <TextView
            android:id="@+id/tvFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="22sp"
            android:textColor="@color/error_red"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_marginBottom="24dp"
            android:visibility="gone"
            android:fontFamily="sans-serif-medium" />

        <!-- Challenge Container -->
        <LinearLayout
            android:id="@+id/llChallengeContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/rounded_card_background"
            android:padding="24dp"
            android:layout_marginBottom="32dp"
            android:elevation="8dp"
            android:clipToPadding="false"
            android:clipChildren="false"
            android:visibility="gone">

            <!-- Challenge Content -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_card_background"
                android:padding="16dp"
                android:layout_margin="8dp"
                android:elevation="4dp">

                <TextView
                    android:id="@+id/tvChallengeDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/challenge_description_placeholder"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/neon_purple"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="sans-serif-condensed" />

                <TextView
                    android:id="@+id/tvBuggyCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/buggy_code_placeholder"
                    android:textSize="14sp"
                    android:textColor="@color/text_light"
                    android:background="@drawable/rounded_edittext_background"
                    android:padding="16dp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="16dp"
                    android:elevation="2dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/choose_correct_fix"
                    android:textSize="16sp"
                    android:textStyle="italic"
                    android:textColor="@color/text_medium"
                    android:layout_marginBottom="16dp"
                    android:fontFamily="sans-serif" />

                <LinearLayout
                    android:id="@+id/llChallengeOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

        </LinearLayout>

        <!-- Buttons at bottom -->
        <!-- Start Game Button -->

        <!-- Back to Dashboard Button -->
        <Button
            android:id="@+id/btnStartGame"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/start_game"
            android:textColor="@color/button_text_light"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingVertical="12dp"
            android:paddingHorizontal="24dp"
            android:background="@drawable/rounded_button_background"
            android:backgroundTint="@color/neon_pink"
            android:layout_gravity="center"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnBackToDashboard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/back_to_dashboard"
            android:textColor="@color/text_medium"
            android:textSize="16sp"
            android:background="@android:color/transparent"
            android:padding="8dp"
            android:layout_gravity="center" />

    </LinearLayout>
</ScrollView>
