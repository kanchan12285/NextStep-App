<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/rounded_card_background"
    android:padding="16dp"
    android:layout_margin="8dp">

    <!-- Article Summary (This was missing!) -->
    <TextView
        android:id="@+id/tvArticleSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Article summary will appear here..."
        android:textSize="14sp"
        android:textColor="@color/text_light"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/choose_best_headline"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/accent_blue"
        android:textAlignment="center"
        android:layout_marginBottom="16dp" />

    <!-- Options Container (This was missing!) -->
    <LinearLayout
        android:id="@+id/llOptionsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <!-- Headline options will be added dynamically -->
    </LinearLayout>

</LinearLayout>
