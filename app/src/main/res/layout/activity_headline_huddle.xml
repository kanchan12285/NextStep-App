<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_background_primary"
    android:gravity="center_horizontal"
    android:padding="24dp"
    tools:context=".HeadlineHuddleActivity">

    <!-- Game Header: Timer and Score -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/timer_placeholder"
            android:textSize="24sp"
            android:textColor="@color/neon_pink"
            android:textStyle="bold"
            android:gravity="start" />

        <TextView
            android:id="@+id/tvScore"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/score_placeholder"
            android:textSize="24sp"
            android:textColor="@color/neon_blue"
            android:textStyle="bold"
            android:gravity="end" />
    </LinearLayout>

    <!-- Instructions -->
    <TextView
        android:id="@+id/tvInstructions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/instructions_headline_huddle"
        android:textSize="18sp"
        android:textColor="@color/text_medium"
        android:textAlignment="center"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/tvFeedback"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="22sp"
        android:textColor="@color/accent_red"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginBottom="24dp"
        android:visibility="gone" />

    <!-- Challenge Content -->
    <LinearLayout
        android:id="@+id/llChallengeContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginBottom="32dp"
        android:visibility="gone"
        android:background="@drawable/rounded_card_background"
        android:padding="16dp"
        android:layout_margin="8dp">

        <TextView
            android:id="@+id/tvArticleSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/article_summary_placeholder"
            android:textSize="16sp"
            android:textColor="@color/text_light"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/choose_best_headline"
            android:textSize="16sp"
            android:textStyle="italic"
            android:textColor="@color/text_medium"
            android:textAlignment="center"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:id="@+id/llOptionsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <!-- Headline options will be added dynamically -->
        </LinearLayout>

    </LinearLayout>

    <!-- Game Control Buttons -->
    <Button
        android:id="@+id/btnStartGame"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/start_game"
        android:textColor="@color/button_text_light"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingVertical="12dp"
        android:paddingHorizontal="24dp"
        android:background="@drawable/rounded_button_background"
        android:backgroundTint="@color/accent_green"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/back_to_dashboard"
        android:textColor="@color/text_medium"
        android:textSize="16sp"
        android:background="@android:color/transparent"
        android:padding="8dp" />

</LinearLayout>
