<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/rounded_card_background"
    android:padding="16dp"
    android:layout_margin="8dp">

    <!-- Challenge Title -->
    <TextView
        android:id="@+id/tvChallengeTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/slogan_challenge_title"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/text_light"
        android:layout_marginBottom="8dp" />

    <!-- Company Name -->
    <TextView
        android:id="@+id/tvCompanyName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/company_name_card_placeholder"
        android:textSize="18sp"
        android:textColor="@color/accent_blue"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginBottom="12dp" />

    <!-- Instructions -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/match_slogan_instruction"
        android:textSize="14sp"
        android:textColor="@color/text_medium"
        android:textAlignment="center"
        android:layout_marginBottom="16dp" />

    <!-- Industry and Difficulty -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvIndustry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/industry_placeholder"
            android:textSize="12sp"
            android:textColor="@color/text_light"
            android:background="@drawable/rounded_button_background"
            android:backgroundTint="@color/accent_green"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tvDifficulty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/difficulty_level_placeholder"
            android:textSize="12sp"
            android:textColor="@color/text_medium"
            android:textStyle="italic" />

    </LinearLayout>

</LinearLayout>
