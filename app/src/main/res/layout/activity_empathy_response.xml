<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/dark_background_primary"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Timer and Score Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Time: 30s"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/neon_pink"
                android:gravity="start" />

            <TextView
                android:id="@+id/tvScore"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Score: 0"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/neon_blue"
                android:gravity="end" />
        </LinearLayout>

        <!-- Instructions -->
        <TextView
            android:id="@+id/tvInstructions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Choose the most empathetic response!"
            android:textSize="18sp"
            android:textColor="@color/text_medium"
            android:textAlignment="center"
            android:layout_marginBottom="32dp" />

        <!-- Feedback Message -->
        <TextView
            android:id="@+id/tvFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/error_red"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:visibility="gone" />

        <!-- Challenge Content -->
        <LinearLayout
            android:id="@+id/llChallengeContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/rounded_card_background"
            android:padding="16dp"
            android:layout_marginBottom="32dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scenario will be here"
                android:textSize="18sp"
                android:textColor="@color/text_light"
                android:textStyle="italic"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:id="@+id/llOptionsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

        <!-- Start Game Button -->
        <Button
            android:id="@+id/btnStartGame"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Start Game"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/button_text_light"
            android:background="@drawable/rounded_button_background"
            android:backgroundTint="@color/accent_green"
            android:paddingVertical="12dp"
            android:paddingHorizontal="24dp"
            android:layout_marginBottom="16dp" />

        <!-- Back to Dashboard -->
        <Button
            android:id="@+id/btnBackToDashboard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back to Dashboard"
            android:textSize="16sp"
            android:textColor="@color/text_medium"
            android:background="@android:color/transparent"
            android:padding="8dp" />

    </LinearLayout>

</ScrollView>
