<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_background_primary"
    android:gravity="center_horizontal"
    android:padding="24dp"
    tools:context=".GameActivity">

    <!-- Game Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <ImageView
            android:id="@+id/ivBackArrow"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back_arrow"
            app:tint="@color/text_light"
            android:contentDescription="@string/back_button_desc"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="16dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/find_yourself_quiz_title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_light"
            android:textAlignment="center" />

        <View
            android:layout_width="32dp"
            android:layout_height="32dp" />

    </LinearLayout>

    <!-- Progress Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="32dp">

        <TextView
            android:id="@+id/tvProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/question_progress_placeholder"
            android:textSize="16sp"
            android:textColor="@color/text_medium"
            android:textAlignment="center"
            android:layout_marginBottom="8dp" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:progress="0"
            android:max="100"
            android:progressTint="@color/accent_purple" />

    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Scenario Title -->
            <TextView
                android:id="@+id/tvScenarioTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/question_placeholder"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_light"
                android:layout_marginBottom="8dp"
                android:textAlignment="center" />

            <!-- Scenario Description -->
            <TextView
                android:id="@+id/tvScenarioDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scenario description goes here"
                android:textSize="16sp"
                android:textColor="@color/text_medium"
                android:layout_marginBottom="16dp"
                android:textAlignment="center" />

            <!-- Choices Container -->
            <LinearLayout
                android:id="@+id/llChoicesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Outcome Text -->
            <TextView
                android:id="@+id/tvOutcomeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Outcome"
                android:textSize="16sp"
                android:textColor="@color/text_light"
                android:visibility="gone"
                android:layout_marginTop="16dp" />

            <!-- Personality Scores -->
            <TextView
                android:id="@+id/tvPersonalityScores"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Personality Scores: ..."
                android:textSize="14sp"
                android:textColor="@color/text_medium"
                android:layout_marginTop="16dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Navigation Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="24dp">

        <Button
            android:id="@+id/btnPrevious"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/previous_button"
            android:textAllCaps="false"
            android:textColor="@color/text_medium"
            android:textSize="16sp"
            android:background="@drawable/rounded_button_background"
            android:backgroundTint="@color/dark_background_secondary"
            android:padding="12dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnNextScenario"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/next_button"
            android:textAllCaps="false"
            android:textColor="@color/button_text_light"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/rounded_button_background"
            android:backgroundTint="@color/accent_purple"
            android:padding="12dp" />

    </LinearLayout>

</LinearLayout>
