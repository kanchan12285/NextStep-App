<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="@color/dark_background_primary">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Report an Issue"
            android:textSize="24sp"
            android:textColor="@color/accent_purple"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="24dp" />

        <!-- Issue Type Spinner -->
        <Spinner
            android:id="@+id/spinnerIssueType"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/rounded_edittext_background"
            android:prompt="@string/select_issue_type"
            android:entries="@array/issue_types"
            android:layout_marginBottom="24dp" />

        <!-- Description Input -->
        <EditText
            android:id="@+id/etIssueDescription"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="@drawable/rounded_edittext_background"
            android:hint="Describe the issue..."
            android:textColor="@color/text_light"
            android:textColorHint="@color/text_medium"
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:padding="16dp"
            android:layout_marginBottom="24dp" />

        <!-- Contact Email Optional -->
        <EditText
            android:id="@+id/etContactEmail"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/rounded_edittext_background"
            android:hint="Your email"
            android:textColor="@color/text_light"
            android:textColorHint="@color/text_medium"
            android:inputType="textEmailAddress"
            android:padding="16dp"
            android:layout_marginBottom="32dp" />

        <!-- Submit Button -->
        <Button
            android:id="@+id/btnSubmitReport"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="@color/accent_purple"
            android:text="Submit"
            android:textColor="@color/text_light"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
