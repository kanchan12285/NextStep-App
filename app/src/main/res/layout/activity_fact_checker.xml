<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background_primary"
    android:padding="24dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Header: Timer & Score -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/timer_placeholder"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/neon_pink"
                android:gravity="start" />

            <TextView
                android:id="@+id/tvScore"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/score_placeholder"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/neon_blue"
                android:gravity="end" />
        </LinearLayout>

        <!-- Instructions -->
        <TextView
            android:id="@+id/tvInstructions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/instructions_fact_checker"
            android:textSize="18sp"
            android:textColor="@color/text_medium"
            android:textAlignment="center"
            android:layout_marginBottom="32dp" />

        <!-- Feedback -->
        <TextView
            android:id="@+id/tvFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/error_red"
            android:textAlignment="center"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:visibility="gone" />

        <!-- Challenge Container -->
        <LinearLayout
            android:id="@+id/llChallengeContent"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/rounded_card_background"
            android:padding="16dp"
            android:layout_margin="8dp"
            android:layout_marginBottom="32dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvStatement"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/fact_statement_placeholder"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/accent_blue"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/is_it_fact_or_fiction"
                android:textSize="16sp"
                android:textStyle="italic"
                android:textColor="@color/text_medium"
                android:layout_marginBottom="24dp"
                android:gravity="center" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnFact"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="@string/fact_button"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/button_text_light"
                    android:paddingVertical="16dp"
                    android:background="@drawable/rounded_button_background"
                    android:backgroundTint="@color/accent_green" />

                <Button
                    android:id="@+id/btnFiction"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="@string/fiction_button"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/button_text_light"
                    android:paddingVertical="16dp"
                    android:background="@drawable/rounded_button_background"
                    android:backgroundTint="@color/accent_red" />
            </LinearLayout>

        </LinearLayout>

        <Button
            android:id="@+id/btnStartGame"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/start_game"
            android:textColor="@color/button_text_light"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/rounded_button_background"
            android:backgroundTint="@color/accent_green"
            android:paddingVertical="12dp"
            android:paddingHorizontal="24dp"
            android:layout_marginBottom="16dp" />

        <!-- Back to Dashboard Button -->
        <Button
            android:id="@+id/btnBackToDashboard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/back_to_dashboard"
            android:textColor="@color/text_medium"
            android:background="@android:color/transparent"
            android:padding="8dp" />
    </LinearLayout>
</ScrollView>
