<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background_primary"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Card Container with Neon Gradient Background -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            app:cardCornerRadius="32dp"
            app:cardElevation="10dp"
            android:background="@color/dark_background_primary"
            android:clipToPadding="false"
            android:clipChildren="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp"
                android:gravity="center_horizontal"
                android:background="@drawable/bg_neon_gradient"
                android:clipToPadding="false"
                android:clipChildren="false">

                <!-- Title -->
                <TextView
                    android:id="@+id/tvCareTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/care_for_you_button"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/neon_purple"
                    android:layout_marginBottom="24dp"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="center" />

                <!-- Subtitle -->
                <TextView
                    android:id="@+id/tvCareSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/care_subtitle"
                    android:textSize="16sp"
                    android:textColor="@color/text_light"
                    android:textAlignment="center"
                    android:layout_marginBottom="24dp"
                    android:letterSpacing="0.03" />

                <!-- Get New Advice Button -->

                <!-- Loading Indicator -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="24dp"
                    android:indeterminateTint="@color/accent_purple"
                    android:visibility="gone" />

                <!-- Response Box -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:elevation="6dp"
                    android:radius="12dp"
                    android:padding="16dp"
                    android:layout_marginTop="24dp"
                    app:cardBackgroundColor="@color/dark_background_secondary">

                    <TextView
                        android:id="@+id/tvResponse"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/response_placeholder"
                        android:textSize="16sp"
                        android:textColor="@color/text_light"
                        android:minHeight="200dp" />
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
