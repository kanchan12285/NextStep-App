<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background_primary"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <androidx.cardview.widget.CardView
            android:id="@+id/cardContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="8dp"
            app:cardCornerRadius="32dp"
            app:cardElevation="10dp"
            android:background="@color/dark_background_primary"
            android:clipToPadding="false"
            android:clipChildren="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp"
                android:gravity="center_horizontal"
                android:background="@drawable/bg_neon_gradient"
                android:clipToPadding="false"
                android:clipChildren="false">

                <!-- User Avatar with Neon Glow -->
                <ImageView
                    android:id="@+id/imgAvatar"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_gravity="center"
                    android:layout_marginBottom="12dp"
                    android:src="@drawable/avatar_placeholder"
                    android:background="@drawable/neon_circle_glow"
                    android:scaleType="centerCrop"
                    android:clipToOutline="true"
                    android:outlineProvider="background" />

                <!-- User Name and Age -->
                <TextView
                    android:id="@+id/tvPlayerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your Name"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/button_text"
                    android:shadowColor="@color/neon_purple"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="8"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tvPlayerAge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Age: 21"
                    android:textSize="16sp"
                    android:textColor="@color/neon_blue"
                    android:layout_marginBottom="14dp"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="center" />

                <!-- Personality Type -->
                <TextView
                    android:id="@+id/tvPersonalityType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="The Logical Thinker"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/neon_purple"
                    android:layout_marginBottom="6dp"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="center" />

                <!-- Personality Description -->
                <TextView
                    android:id="@+id/tvPersonalityDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Description goes here"
                    android:textSize="16sp"
                    android:textColor="@color/text_light"
                    android:gravity="center_horizontal"
                    android:layout_marginBottom="20dp"
                    android:lineSpacingExtra="4dp"
                    android:paddingHorizontal="12dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="@drawable/neon_divider"
                    android:layout_marginBottom="12dp"
                    android:layout_marginTop="8dp" />

                <!-- Traits Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your Key Traits"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/neon_purple"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="sans-serif-condensed" />

                <!-- Traits list container -->
                <LinearLayout
                    android:id="@+id/traitsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Download and Share Buttons outside the card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <Button
                android:id="@+id/btnDownloadCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Download"
                android:textAllCaps="false"
                android:backgroundTint="@color/neon_blue"
                android:textColor="@color/text_light"
                android:drawableLeft="@drawable/ic_download"
                android:padding="12dp"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnShareCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Share"
                android:textAllCaps="false"
                android:backgroundTint="@color/neon_pink"
                android:textColor="@color/text_light"
                android:drawableLeft="@drawable/ic_share"
                android:padding="12dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
