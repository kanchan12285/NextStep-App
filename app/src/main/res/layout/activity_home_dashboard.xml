<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    tools:context=".HomeDashboardActivity"
    tools:openDrawer="start">

    <!-- Main content container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/dark_background_primary"
        android:fitsSystemWindows="true">

        <!-- Top Bar with NextStep title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@color/dark_background_secondary"
            android:fitsSystemWindows="true">

            <ImageView
                android:id="@+id/ivHamburgerMenu"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_menu"
                app:tint="@color/neon_purple"
                android:contentDescription="@string/menu_desc" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="NextStep"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed"
                android:textColor="@color/button_text"
                android:layout_marginStart="16dp" />

            <ImageView
                android:id="@+id/ivSettingsIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_settings"
                app:tint="@color/neon_purple"
                android:contentDescription="@string/settings_desc"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Scrollable content -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fitsSystemWindows="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp"
                android:gravity="center_horizontal"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:background="@drawable/bg_neon_gradient">

                <!-- User Profile Header -->
                <LinearLayout
                    android:id="@+id/llUserProfileHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="32dp"
                    android:background="@drawable/rounded_card_background"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="8dp"
                    android:clipToPadding="false"
                    android:clipChildren="false">

                    <ImageView
                        android:id="@+id/imgUserAvatar"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/avatar_1"
                        android:background="@drawable/avatar_selector_background"
                        android:contentDescription="@string/avatar_desc"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvWelcomeMessage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hello, kanchan!"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-condensed"
                            android:textColor="@color/neon_purple" />

                        <TextView
                            android:id="@+id/tvProfileSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ready for your next step?"
                            android:textSize="16sp"
                            android:textColor="@color/text_light" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Find Yourself Button Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:strokeWidth="0dp"
                    app:strokeColor="@android:color/transparent"
                    app:cardUseCompatPadding="false"
                    app:cardPreventCornerOverlap="true"
                    android:clipToPadding="false"
                    android:clipChildren="false"
                    android:padding="10dp">

                    <Button
                        android:id="@+id/btnFindYourself"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="FIND YOURSELF"
                        android:textColor="@color/button_text_light"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_neon_gradient_button"
                        android:paddingVertical="16dp" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Mini Games Button Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="32dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:strokeWidth="0dp"
                    app:strokeColor="@android:color/transparent"
                    app:cardUseCompatPadding="false"
                    app:cardPreventCornerOverlap="true"
                    android:clipToPadding="false"
                    android:clipChildren="false"
                    android:padding="10dp">

                    <Button
                        android:id="@+id/btnMiniGames"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="MINI GAMES"
                        android:textColor="@color/button_text_light"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_neon_gradient_button"
                        android:paddingVertical="16dp" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Play With Friend and Play Online Buttons Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="32dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_marginEnd="16dp"
                        app:cardCornerRadius="60dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:strokeWidth="0dp"
                        app:strokeColor="@android:color/transparent"
                        app:cardUseCompatPadding="false"
                        app:cardPreventCornerOverlap="true"
                        android:clipToPadding="false"
                        android:clipChildren="false">

                        <Button
                            android:id="@+id/btnPlayWithFriend"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="PLAY WITH\nFRIEND"
                            android:textColor="@color/button_text_light"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_neon_gradient_button_circle"
                            android:gravity="center" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_marginStart="16dp"
                        app:cardCornerRadius="60dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:strokeWidth="0dp"
                        app:strokeColor="@android:color/transparent"
                        app:cardUseCompatPadding="false"
                        app:cardPreventCornerOverlap="true"
                        android:clipToPadding="false"
                        android:clipChildren="false">

                        <Button
                            android:id="@+id/btnPlayOnline"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="PLAY\nONLINE"
                            android:textColor="@color/button_text_light"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_neon_gradient_button_circle"
                            android:gravity="center" />
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Know Me Card Button Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:strokeWidth="0dp"
                    app:strokeColor="@android:color/transparent"
                    app:cardUseCompatPadding="false"
                    app:cardPreventCornerOverlap="true"
                    android:clipToPadding="false"
                    android:clipChildren="false"
                    android:padding="10dp">

                    <Button
                        android:id="@+id/btnKnowMeCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="KNOW ME CARD"
                        android:textColor="@color/button_text_light"
                        android:textSize="18sp"
                        android:background="@drawable/bg_neon_gradient_button"
                        android:paddingVertical="14dp" />
                </com.google.android.material.card.MaterialCardView>

                <!-- C.A.R.E. for You Button Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:strokeWidth="0dp"
                    app:strokeColor="@android:color/transparent"
                    app:cardUseCompatPadding="false"
                    app:cardPreventCornerOverlap="true"
                    android:clipToPadding="false"
                    android:clipChildren="false"
                    android:padding="10dp">

                    <Button
                        android:id="@+id/btnCareForYou"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="C.A.R.E FOR YOU"
                        android:textColor="@color/button_text_light"
                        android:textSize="18sp"
                        android:background="@drawable/bg_neon_gradient_button"
                        android:paddingVertical="14dp" />
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/dark_background_secondary"
        android:elevation="0dp"
        app:headerLayout="@layout/nav_header_main"
        app:itemTextColor="@color/neonText"
        app:menu="@menu/nav_drawer_menu" />
</androidx.drawerlayout.widget.DrawerLayout>
